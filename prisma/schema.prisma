datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("employee")
  color         String    @default("#2563EB")
  initials      String    @default("??")
  browniePoints Int       @default(0)
  createdAt     DateTime  @default(now())
  
  accounts      Account[]
  sessions      Session[]
  
  workspaceMembers WorkspaceMember[]
  tasksAssigned    Task[]  @relation("AssignedTasks")
  tasksCreated     Task[]  @relation("CreatedTasks")
  notifications    Notification[]
  attendance       Attendance[]
  profile          EmployeeProfile?
  documents        EmployeeDocument[]
  credentials      Credential[]     @relation("CredentialUser")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Workspace {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  subscriptionPlan String   @default("Free")
  defaultWorkHours Float    @default(8)
  createdAt        DateTime @default(now())

  members          WorkspaceMember[]
  tasks            Task[]
  notifications    Notification[]
}

model WorkspaceMember {
  id            String   @id @default(cuid())
  workspaceId   String
  userId        String
  role          String   @default("employee")
  browniePoints Int      @default(0)
  color         String   @default("#2563EB")
  initials      String   @default("??")
  createdAt     DateTime @default(now())

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Task {
  id           String   @id @default(cuid())
  workspaceId  String
  title        String
  desc         String?
  status       String   @default("open")
  category     String?
  priority     String   @default("medium")
  type         String   @default("assigned")
  weight       Int      @default(5)      // 1-10 complexity/importance for productivity
  dueAt        DateTime?
  refLink      String?
  subText      String?
  subLink      String?
  fbText       String?
  adminScore   Int?     // Score given by admin out of 5
  productivity Float?   // Derived: (weight * score) / hours
  pickedUpAt   DateTime?  // when employee starts working
  completedAt  DateTime?  // when admin approves/rejects
  events       String?  // Stored as JSON string due to SQLite constraints
  comments     String?  // Stored as JSON string
  createdAt    DateTime @default(now())

  assignedToId String?
  assignee   User?    @relation("AssignedTasks", fields: [assignedToId], references: [id])
  
  createdById  String
  createdBy    User     @relation("CreatedTasks", fields: [createdById], references: [id])
  
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  notifications Notification[]
}

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  text        String
  type        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Attendance {
  id          String    @id @default(cuid())
  userId      String
  date        String    // "2026-04-08" — one record per user per day
  clockIn     DateTime?
  clockOut    DateTime?
  status        String    @default("present") // present | halfday | leave | wfh
  hoursWorked   Float?
  morningProd   String?   // "Productive" | "Not productive"
  afternoonProd String?   // "Productive" | "Not productive"
  adminNote     String?
  createdAt     DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model EmployeeProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  designation     String?
  department      String?
  monthlySalary   Float?
  workingHoursDay Float    @default(8)
  roleDesc        String?
  customFields    String?  // JSON for extensible fields
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Credential {
  id          String   @id @default(cuid())
  toolName    String
  toolUrl     String?
  loginEmail  String?
  loginPass   String?        // Stored encrypted/obfuscated
  apiKey      String?
  assignedToId String?
  assignedTo  User?    @relation("CredentialUser", fields: [assignedToId], references: [id])
  renewalDate String?        // "2026-12-31"
  monthlyCost  Float   @default(0)
  billingCycle String  @default("monthly")  // "monthly" | "yearly"
  sharedWith   String? // JSON array of user IDs
  notes       String?
  createdAt   DateTime @default(now())
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  userId      String
  docType     String          // "pan" | "aadhaar" | "certificate"
  fileName    String
  blobUrl     String          // Azure Blob URL
  blobPath    String          // path in container for deletion
  uploadedAt  DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

